# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# --- Application Settings ---
APP_ENV=development
APP_NAME=PortfolioOptimizerNSE
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# --- Security ---
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
API_RATE_LIMIT=100

# --- Redis Cache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=300

# --- MLflow Tracking ---
MLFLOW_TRACKING_URI=sqlite:///mlflow_server/mlflow.db
MLFLOW_EXPERIMENT_NAME=portfolio_optimizer_nse
MLFLOW_ARTIFACT_ROOT=./mlflow_artifacts

# --- Model Settings ---
LSTM_SEQUENCE_LENGTH=60
LSTM_BATCH_SIZE=32
LSTM_MAX_EPOCHS=100
LSTM_PATIENCE=10

PROPHET_FORECAST_HORIZON=30

RL_TOTAL_TIMESTEPS=500000
RL_LEARNING_RATE=0.0003

# --- Data Settings ---
NSE_TICKERS=RELIANCE.NS,TCS.NS,HDFCBANK.NS,INFY.NS,ICICIBANK.NS,WIPRO.NS,BAJFINANCE.NS,ASIANPAINT.NS,TITAN.NS,MARUTI.NS,ONGC.NS,ZOMATO.NS
BENCHMARK_TICKERS=^NSEI,^BSESN
DATA_LOOKBACK_YEARS=5
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_BENCHMARKS_DIR=data/benchmarks

# --- Portfolio Constraints ---
MIN_STOCK_WEIGHT=0.0
MAX_STOCK_WEIGHT=0.30
INITIAL_CAPITAL_INR=1000000
TRANSACTION_COST_PCT=0.001

# --- Alert Settings ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=alerts@yourfirm.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# --- Drift Detection Thresholds ---
PSI_THRESHOLD=0.2
KS_PVALUE_THRESHOLD=0.05
MAPE_DEGRADATION_THRESHOLD=0.20
DIRECTIONAL_ACCURACY_THRESHOLD=0.50

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
MLFLOW_PORT=5000
