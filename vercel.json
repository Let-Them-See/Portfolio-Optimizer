{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/main.py" }
  ],
  "env": {
    "JWT_SECRET_KEY": "@jwt_secret_key",
    "DEMO_PASSWORD": "@demo_password",
    "REDIS_URL": "@redis_url"
  }
}
